# Bật MOCK_MODE=1 để chạy thử KHÔNG cần API key (trả về project mẫu).
MOCK_MODE=1

# Endpoint dạng OpenAI-compatible (KHÔNG kèm /chat/completions — code tự nối).
QWEN_BASE_URL=https://openrouter.ai/api/v1
QWEN_API_KEY=
QWEN_MODEL=qwen/qwen3-coder
QWEN_MAX_TOKENS=32000
QWEN_TIMEOUT_MS=120000
QWEN_JSON_MODE=1

RAG_ENABLED=1
RAG_TOP_K=6
RAG_STORE=memory
CHROMA_URL=http://localhost:8000

REVIEW_ENABLED=1
REVIEW_AUTOFIX=1
# Số VÒNG reflection tối đa (sinh→phê bình→sửa).
REVIEW_MAX_ROUNDS=2
REVIEW_USE_LLM_CRITIC=1

# Gemini Flash (free) — Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# gpt-oss-120b (free, limit cao) — Cerebras: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# LLM-as-Judge
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.deepseek.com
JUDGE_MODEL=deepseek-chat

PORT=8787