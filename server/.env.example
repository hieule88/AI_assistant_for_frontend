# ---- Cách truy cập model Qwen3-Coder (OpenAI-compatible) ----
# Bật MOCK_MODE=1 để chạy thử KHÔNG cần API key (trả về project mẫu).
# Khi có endpoint thật, đặt MOCK_MODE=0 và điền 3 dòng QWEN_* dưới.
MOCK_MODE=1

# Endpoint dạng OpenAI-compatible (KHÔNG kèm /chat/completions — code tự nối).
# Chọn 1 trong các provider sau (xem hướng dẫn lấy key bên dưới):
#   - OpenRouter (dễ nhất cho SV): https://openrouter.ai/api/v1
#   - DashScope (Alibaba):         https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   - Self-host (vLLM):            http://localhost:8000/v1
QWEN_BASE_URL=https://openrouter.ai/api/v1

# API key của provider tương ứng.
QWEN_API_KEY=sk-xxxxx

# Tên (slug) model — PHẢI khớp đúng với provider. KIỂM TRA trang model list của provider:
#   - OpenRouter: ví dụ "qwen/qwen3-coder"  (mở https://openrouter.ai/models, tìm "qwen coder")
#   - DashScope:  ví dụ "qwen3-coder-plus"  (xem Model Studio)
QWEN_MODEL=qwen/qwen3-coder

# ---- Tinh chỉnh (có giá trị mặc định, thường không cần đổi) ----
# Số token tối đa cho 1 lần sinh. 1 trang HTML đầy đủ rất tốn token; thấp quá sẽ bị CẮT CỤT
# (model trả JSON dở dang -> ParseError). 32000 hợp cho landing page; tăng nếu trang lớn.
QWEN_MAX_TOKENS=32000
# Hủy request nếu model treo (ms).
QWEN_TIMEOUT_MS=120000
# Ép model trả đúng 1 JSON object (đặt =1 nếu provider hỗ trợ; DashScope/OpenRouter thường có).
QWEN_JSON_MODE=1

# ---- Code RAG (Bước 3) ----
# Bật/tắt truy xuất RAG (1=bật mặc định, 0=tắt để so sánh "không RAG" ở Bước 4).
RAG_ENABLED=1
# Số component lấy về nhồi vào prompt (6 hợp để sinh cả trang nhiều section;
# cao hơn = prompt dài hơn = tốn token hơn khi dùng model thật).
RAG_TOP_K=6
# Backend lưu vector:
#   memory = cosine in-process, ghi rag-index.json — KHÔNG cần cài gì (mặc định, hợp dev/test).
#   chroma = dùng Chroma (đúng kiến trúc chốt) — cần chạy: pip install chromadb && chroma run --path ./chroma_db
RAG_STORE=memory
CHROMA_URL=http://localhost:8000

# ---- Review Agent (Bước 6) ----
# Bật/tắt soát HTML sau khi sinh (1=bật mặc định).
REVIEW_ENABLED=1
# Nếu có lỗi, gọi model sửa 1 vòng (1=bật). Đặt 0 để chỉ báo lỗi, không tốn token sửa.
REVIEW_AUTOFIX=1

PORT=8787
